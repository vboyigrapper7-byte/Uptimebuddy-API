{
  "name": "monitorhub-backend",
  "version": "1.0.0",
  "description": "Monitor Hub SaaS Platform Backend API",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "migrate": "node-pg-migrate",
    "start": "concurrently --kill-others-on-fail -n API,WORKERS -c cyan,green \"npm run migrate up && node src/server.js\" \"node src/workers/index.js\"",
    "start:render": "npm run start",
    "start:api": "npm run migrate up && node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:all": "concurrently --kill-others-on-fail -n API,CHECK,ALERT -c cyan,green,yellow \"npm run migrate up && node --watch src/server.js\" \"node --watch src/workers/checkWorker.js\" \"node --watch src/workers/alertWorker.js\"",
    "workers": "concurrently -n CHECK,ALERT -c green,yellow \"node --watch src/workers/checkWorker.js\" \"node --watch src/workers/alertWorker.js\"",
    "workers:prod": "concurrently -n CHECK,ALERT -c green,yellow \"node src/workers/checkWorker.js\" \"node src/workers/alertWorker.js\"",
    "workers:check": "node src/workers/checkWorker.js",
    "workers:alert": "node src/workers/alertWorker.js",
    "test": "node --test \"tests/**/*.js\""
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^8.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "axios": "^1.14.0",
    "bcrypt": "^5.0.1",
    "bullmq": "^5.73.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.10.1",
    "jsonpath": "^1.3.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "razorpay": "^2.9.6",
    "resend": "^3.5.0",
    "tcp-ping": "^0.1.1",
    "winston": "^3.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
